# ========================================
# AIRFLOW CORE
# ========================================
AIRFLOW_UID=1000
AIRFLOW_BASE_IMAGE=apache/airflow:3.2.1
AIRFLOW_IMAGE_NAME=amalitech-airflow:3.2.1
AIRFLOW_PROJ_DIR=.

# Security & Auth
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate JWT secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__API_AUTH__JWT_SECRET=
AIRFLOW__API_AUTH__JWT_ISSUER=airflow
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=

# ========================================
# POSTGRES (Airflow Metadata + Target DB)
# ========================================
POSTGRES_USER=airflow
POSTGRES_PASSWORD=
POSTGRES_DB=airflow
TARGET_DB=target

# ========================================
# MINIO
# ========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# ========================================
# SMTP (email alerts on DAG failure)
# ========================================
# Gmail: create App Password at https://myaccount.google.com/apppasswords
# Host/port/tls configured in config/airflow.cfg [smtp] section
AIRFLOW_SMTP_USER=
AIRFLOW_SMTP_PASSWORD=
AIRFLOW_ALERT_EMAIL=
